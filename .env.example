# docker-compose.prod.yml 이 읽는 민감값 템플릿.
#   서버에서:  cp .env.example .env  후 실제 값으로 채운다.
#   .env 는 .gitignore 로 제외됨(커밋 금지). 이 .example 만 저장소에 둔다.

# JWT 서명 시크릿 — 반드시 긴 랜덤 문자열로 교체할 것.
#   예) openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# 컨테이너 MySQL 비밀번호(앱·DB 양쪽에 동일 적용). 학습용이면 기본값 유지 가능.
ERP_DB_PASSWORD=erp
MES_DB_PASSWORD=mes

# ── AI 어시스턴트(선택) — 이 맥에서 도는 에이전트를 Cloudflare Tunnel 로 호출할 때만 ──
# 에이전트 공개 주소(터널). 안 쓰면 비워두면 됨(챗봇은 "연결 불가" 로만 표시).
ERP_AGENT_BASE_URL=https://agent.hyunwoo.pro
# 에이전트 인증 공유키 — 이 맥 erp-agent/.env 의 AGENT_SECRET 과 반드시 같은 값.
#   생성 예) openssl rand -hex 32
ASSISTANT_AGENT_SECRET=change-me-same-as-agent-side

# ── 방문 통계 /stats 로그인 (hyunwoo.pro/stats) ──────────────────
# 이 계정을 모르면 통계 페이지를 볼 수 없다.
#   안 채워도 사이트는 정상 동작한다(/stats 만 아무도 못 여는 상태가 됨).
#   → 통계를 보려면 채울 것.
STATS_USER=admin
# 평문 아님 — bcrypt 해시를 넣는다. 생성:
#   docker run --rm caddy:2 caddy hash-password --plaintext '원하는비번'
#
# ⚠️⚠️ 해시의 $ 를 전부 $$ 로 바꿔서 넣을 것. 이거 안 하면 로그인이 안 된다.
#   docker compose 는 .env 값 안의 $ 를 변수 참조로 해석해버린다.
#   그대로 넣으면 해시가 60자 → 50자로 잘린 채 Caddy 에 전달되어 계속 401.
#
#   생성된 해시:  $2a$14$TyeOi....
#   .env 에 넣을 값: $$2a$$14$$TyeOi....
#
#   변환 한 줄:
#     echo '<해시>' | sed 's/\$/$$/g'
#
#   확인:  docker exec hwlee-caddy printenv STATS_PASSWORD_HASH | wc -c   # 61 이면 정상
STATS_PASSWORD_HASH=
# 리포트 갱신 주기(초). 기본 300 = 5분.
STATS_INTERVAL=300
