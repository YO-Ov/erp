# docker-compose.prod.yml 이 읽는 민감값 템플릿.
#   서버에서:  cp .env.example .env  후 실제 값으로 채운다.
#   .env 는 .gitignore 로 제외됨(커밋 금지). 이 .example 만 저장소에 둔다.

# JWT 서명 시크릿 — 반드시 긴 랜덤 문자열로 교체할 것.
#   예) openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# 컨테이너 MySQL 비밀번호(앱·DB 양쪽에 동일 적용). 학습용이면 기본값 유지 가능.
ERP_DB_PASSWORD=erp
MES_DB_PASSWORD=mes
