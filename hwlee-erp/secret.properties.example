# === hwlee-erp 민감값 템플릿 ===
# 이 파일을 같은 위치에 secret.properties 로 복사한 뒤 실제 값을 채우세요.
#   cp secret.properties.example secret.properties
# secret.properties 는 .gitignore 로 제외되어 git 에 올라가지 않습니다.
# aws 프로필(application-aws.yml)에서 spring.config.import 로 읽어들입니다.

# 회사 RDS(MySQL) erp_app 유저 비밀번호
ERP_DB_PASSWORD=

# JWT 서명 시크릿 (운영용 — 로컬 기본값 대신 충분히 긴 랜덤 문자열 권장)
JWT_SECRET=
