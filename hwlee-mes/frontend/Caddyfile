# ─────────────────────────────────────────────────────────────
# MES 프론트엔드 정적 서버 (컨테이너 내부 :80)
#   - 바깥 메인 Caddy(mes.hyunwoo.pro)가 '/api/*' 는 백엔드로,
#     그 외 전부를 이 컨테이너로 프록시한다.
#   - 여기서는 Vue 빌드 산출물(/srv)만 서빙 + SPA 딥링크 폴백.
#   - 내부 통신이므로 TLS 불필요(HTTP :80). 자동 HTTPS 비활성.
# ─────────────────────────────────────────────────────────────
{
	auto_https off
	admin off
}

:80 {
	root * /srv
	encode gzip zstd

	# ── 캐시 정책 (ERP 프론트와 동일) ─────────────────────────────
	#   /assets/* 는 파일명에 내용 해시가 붙어 오래 캐시해도 안전하다.
	#   반면 index.html 은 이름이 고정이라 캐시되면 새로 배포해도 브라우저가
	#   옛 index.html → 옛 번들을 계속 쓴다(2026-07-20 ERP 에서 실제로 겪음).
	#   no-cache = "캐시하되 쓸 때마다 서버에 확인" → 평소엔 304, 배포 직후엔 즉시 최신.
	#   ⚠️ SPA 폴백 때문에 임의 경로도 index.html 을 받으므로 assets 외 전부에 건다.
	@no-cache not path /assets/*
	header @no-cache Cache-Control "no-cache"

	# 존재하는 파일이면 그대로, 없으면 index.html 로 폴백(클라이언트 라우팅).
	try_files {path} /index.html
	file_server
}
