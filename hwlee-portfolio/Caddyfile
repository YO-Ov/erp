# ─────────────────────────────────────────────────────────────
# 포트폴리오 정적 서버 (컨테이너 내부 :80)
#   바깥 메인 Caddy(hyunwoo.pro)가 전부 이 컨테이너로 프록시한다.
#   단일 페이지라 SPA 폴백만 두면 어떤 경로든 index.html 로 응답.
#   내부 통신이므로 TLS 불필요(HTTP :80). 자동 HTTPS 비활성.
# ─────────────────────────────────────────────────────────────
{
	auto_https off
	admin off
}

:80 {
	root * /srv
	encode gzip zstd
	# ── 캐시 정책 (ERP·MES 프론트와 동일) ────────────────────────
	#   이 사이트는 단일 index.html 이라 사실상 전부 no-cache 다.
	#   내용을 고쳐 배포해도 브라우저가 옛 페이지를 계속 보여주는 걸 막는다.
	#   (해시 붙은 정적 파일을 나중에 쓰게 되면 /assets/* 는 자동으로 길게 캐시된다)
	@no-cache not path /assets/*
	header @no-cache Cache-Control "no-cache"

	try_files {path} /index.html
	file_server
}
